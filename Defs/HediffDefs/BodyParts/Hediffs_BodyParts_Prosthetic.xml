  <ThingDef ParentName="BodyPartExplosiveMakeableBase">
    <defName>PrimedExplosivesThing</defName>
    <label>primed explosives I</label>
    <description>A torso implant that consists of condensed explosive material. Since it is far deeper in the body, outside forces cannot penetrate and accidentally detonate the material. Being an implant, it is less cumbersome than a vest, but a detonation results in certain death of the user.</description>
    <descriptionHyperlinks><RecipeDef>InstallPrimedExplosives</RecipeDef></descriptionHyperlinks>
    <costList>
      <Steel>20</Steel>
	  <Chemfuel>20</Chemfuel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <techHediffsTags>
      <li>Simple</li>
    </techHediffsTags>
  </ThingDef>
  
