  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>InstallPrimedExplosives</defName>
    <label>install primed explosives I</label>
    <description>Install a batch of primed explosives I.</description>
    <descriptionHyperlinks>
      <ThingDef>PrimedExplosivesThing</ThingDef>
      <HediffDef>PrimedExplosivesHed</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing primed explosives I.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>PrimedExplosivesThing</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>PrimedExplosivesThing</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Torso</li>
    </appliedOnFixedBodyParts>
    <addsHediff>PrimedExplosivesHed</addsHediff>
  </RecipeDef>
  
