<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef Name="BodyPartExplosiveBase" ParentName="BodyPartBase" Abstract="True">
    <techLevel>Industrial</techLevel>
    <thingCategories>
      <li>BodyPartsProsthetic</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Item/Health/HealthItem</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.80</drawSize>
      <color>(154,124,104)</color>
    </graphicData>
    <statBases>
      <WorkToMake>15000</WorkToMake>
    </statBases>
    <recipeMaker>
      <displayPriority>600</displayPriority>
    </recipeMaker>
  </ThingDef>
  
  <ThingDef ParentName="UnfinishedBase">
    <defName>UnfinishedHealthItemExplosive</defName>
    <label>unfinished explosive implant</label>
    <description>An unfinished explosive implant.</description>
    <statBases>
      <Flammability>0.5</Flammability>
    </statBases>
    <graphicData>
      <texPath>Things/Item/Unfinished/UnfinishedHealthItem</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(154,124,104)</color>
    </graphicData>
    <stuffCategories Inherit="false" />
  </ThingDef>
  
  <ThingDef Name="BodyPartExplosiveMakeableBase" ParentName="BodyPartExplosiveBase" Abstract="True">
    <recipeMaker>
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Smith</effectWorking>
      <soundWorking>Recipe_Smith</soundWorking>
      <recipeUsers>
        <li>TableMachining</li>
      </recipeUsers>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <unfinishedThingDef>UnfinishedHealthItemExplosive</unfinishedThingDef>
      <researchPrerequisite>EVWS_ExplosiveImplants</researchPrerequisite>
    </recipeMaker>
  </ThingDef>
  
	<HediffDef ParentName="ImplantHediffBase">
    <defName>PrimedExplosivesHed</defName>
    <label>primed explosives I</label>
    <labelNoun>a batch of primed explosives</labelNoun>
    <description>An installed torso implant that consists of condensed explosive material. Cannot be penetrated as easily and thus avoids the risk of accidental detonation. However, a detonation results in certain death of the user.</description>
    <descriptionHyperlinks><ThingDef>PrimedExplosivesThing</ThingDef></descriptionHyperlinks>
    <spawnThingOnRemoved>PrimedExplosivesThing</spawnThingOnRemoved>
	<comps>
		<li Class="ExplosiveVest.HediffCompProperties_PrimedExplosives">
			<minRadius>3.0</minRadius>
			<maxRadius>5.0</maxRadius>
			<minDamage>50</minDamage>
			<maxDamage>75</maxDamage>
			<fireChance>0.1</fireChance>
			<damChance>1.35</damChance>
		</li>
	</comps>
  </HediffDef>
  
