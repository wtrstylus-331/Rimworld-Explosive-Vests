<ThingDef ParentName="ArmorMachineableBase">
    <defName>EVWS_VestTierOne</defName>
    <description>A vest rigged with explosive material with a small blast radius.</description>
    <label>explosive vest I</label>
    <recipeMaker>
      <researchPrerequisite>EVWS_ExplosiveVests</researchPrerequisite>
	  <unfinishedThingDef>UnfinishedExplosiveVest</unfinishedThingDef>
	  <skillRequirements>
			<Crafting>4</Crafting>
		</skillRequirements>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/EVest/EVest</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <costList>
      <Cloth>10</Cloth>
      <Steel>30</Steel>
	  <Chemfuel>20</Chemfuel>
    </costList>
    <thingCategories>
      <li>ApparelExplosiveVest</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <WorkToMake>7000</WorkToMake>
      <Mass>4</Mass>
	  <Flammability>0.6</Flammability>
      <ArmorRating_Sharp>0.90</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.30</ArmorRating_Blunt>
      <ArmorRating_Heat>0.20</ArmorRating_Heat>
      <Insulation_Cold>1</Insulation_Cold>
      <EquipDelay>4</EquipDelay>
    </statBases>
	<equippedStatOffsets>
      <MoveSpeed>-0.10</MoveSpeed>
	  <MentalBreakThreshold>0.10</MentalBreakThreshold>
	  <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">0.15</SlaveSuppressionOffset>
    </equippedStatOffsets>
	<!--generateAllowChance>0</generateAllowChance-->
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/EVest/EVest</wornGraphicPath>
      <layers>
        <li>Middle</li>
      </layers>
	  <tags>
	  <li>EVWS_ExplosiveVest</li>
	  </tags>
    </apparel>
	<comps>
		<li Class="ExplosiveVest.CompProperties_ExplosiveVest">
			<minRadius>3.0</minRadius>
			<maxRadius>5.0</maxRadius>
